# UICopilot — environment configuration
# Copy to .env and fill in values. Never commit .env.

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Database (aiosqlite — add when implementing repositories)
# DATABASE_URL=sqlite:///./data/uicopilot.db

# Scoring config override (leave blank to use config/scoring.json)
# SCORING_CONFIG_PATH=
